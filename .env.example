# =====================================================================
# Real Bee — Local Development Environment
# =====================================================================
# Copy this file to .env and fill in your values.
# Never commit a .env file containing real secrets.

# --- Supabase Auth ---------------------------------------------------
# Vite only exposes VITE_-prefixed vars to browser bundles.
# The VITE_ versions below are for client-side (Vite) use.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Non-prefixed aliases required by the Phase 0 compliance checklist
# (used by server-side tooling, CI, or future edge functions).
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# --- Wrangler Secrets (NOT stored in .env) ---------------------------
# Set via: wrangler secret put GEMINI_API_KEY
# GEMINI_API_KEY is never injected into the client bundle.
# Do not uncomment the line below in production — use wrangler secrets.
# GEMINI_API_KEY=""

# --- Cloudflare D1 ---------------------------------------------------
# D1 bindings are declared in wrangler.toml, not .env.
# Binding: DB  |  Database name: real-bee-db
# See wrangler.toml [[d1_databases]] for the full configuration.

# --- Observability ---------------------------------------------------
# Client-side Sentry DSN (Vite-injected into browser bundle)
VITE_SENTRY_DSN=""

# Server-side Sentry DSN (used by Cloudflare Pages Functions middleware)
SENTRY_DSN=""

# --- App -------------------------------------------------------------
APP_URL="http://localhost:5173"

# --- Provider Configuration (Client-Side) ----------------------------
# VITE_-prefixed vars are injected into the browser bundle by Vite.
# These control which provider the client-side API clients will attempt
# to use first (before falling back to browser-native APIs).
#
# TTS providers: 'gemini' (default) | 'elevenlabs'
VITE_TTS_PROVIDER="gemini"
#
# STT providers: 'gemini' (default) | 'cloudflare-whisper' | 'deepgram'
VITE_STT_PROVIDER="gemini"

# --- Provider Configuration (Server-Side) ----------------------------
# These are set as Wrangler variables (not in .env) to control which
# provider the Cloudflare Workers should route to.
# Set via wrangler.toml [vars] or `wrangler secret put`:
#   TTS_PROVIDER="gemini"
#   STT_PROVIDER="gemini"

# --- Provider API Keys (Set via `wrangler secret put`) ---------------
# These are never committed to version control. Set them with:
#   wrangler secret put ELEVENLABS_API_KEY
#   wrangler secret put DEEPGRAM_API_KEY
#
# ElevenLabs Flash v2.5 TTS (production-quality voices)
# ELEVENLABS_API_KEY=""
#
# Deepgram Nova-3 STT (production-quality transcription)
# DEEPGRAM_API_KEY=""
