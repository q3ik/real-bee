# =====================================================================
# Real Bee — Local Development Environment
# =====================================================================
# Copy this file to .env and fill in your values.
# Never commit a .env file containing real secrets.

# --- Supabase Auth ---------------------------------------------------
# Vite only exposes VITE_-prefixed vars to browser bundles.
# The VITE_ versions below are for client-side (Vite) use.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Non-prefixed aliases required by the Phase 0 compliance checklist
# (used by server-side tooling, CI, or future edge functions).
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# --- Wrangler Secrets (NOT stored in .env) ---------------------------
# Set via: wrangler secret put GEMINI_API_KEY
# GEMINI_API_KEY is never injected into the client bundle.
# Do not uncomment the line below in production — use wrangler secrets.
# GEMINI_API_KEY=""

# --- Cloudflare D1 ---------------------------------------------------
# D1 bindings are declared in wrangler.toml, not .env.
# Binding: DB  |  Database name: real-bee-db
# See wrangler.toml [[d1_databases]] for the full configuration.

# --- Observability ---------------------------------------------------
# Client-side Sentry DSN (Vite-injected into browser bundle)
VITE_SENTRY_DSN=""

# Server-side Sentry DSN (used by Cloudflare Pages Functions middleware)
SENTRY_DSN=""

# --- App -------------------------------------------------------------
APP_URL="http://localhost:5173"
