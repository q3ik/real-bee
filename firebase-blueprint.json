{
  "entities": {
    "UserProgress": {
      "title": "User Progress",
      "description": "Stores user's spelling bee performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "score": { "type": "integer" },
        "streak": { "type": "integer" },
        "bestStreak": { "type": "integer" },
        "masteredCount": { "type": "integer" },
        "gradeLevel": { "type": "string" },
        "difficulty": { "type": "string" },
        "lastPlayed": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "score", "streak", "masteredCount"]
    },
    "Session": {
      "title": "Game Session",
      "description": "Stores details of a single spelling bee session.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "wordsSpelled": { "type": "integer" },
        "correctCount": { "type": "integer" },
        "difficultyEvolution": { "type": "array", "items": { "type": "number" } }
      },
      "required": ["uid", "startTime"]
    },
    "Feedback": {
      "title": "User Feedback",
      "description": "Stores bug reports and feedback from users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "message": { "type": "string" },
        "diagnosticState": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["message", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProgress",
      "description": "User progress data."
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Game session history."
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback and bug reports."
    }
  }
}
